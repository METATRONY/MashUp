# Spotify API (https://developer.spotify.com/dashboard)
# Used for album art and confirmed artist/title metadata only.
# Note: audio_features (BPM, key, energy) returns 403 for new apps — use GetSongBPM + Essentia instead.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# GetSongBPM API (https://getsongbpm.com/api)
# Primary source for exact BPM and key. Falls back to Essentia local analysis if absent.
GETSONGBPM_API_KEY=your_getsongbpm_api_key_here

# Genius API (https://genius.com/developers)
# Required for full lyrics. Falls back to lrclib.net (free, no key) if absent.
GENIUS_ACCESS_TOKEN=your_genius_access_token_here
